*.tfvars.json

# AWS / 环境文件
.env
.env.*
.aws/

# Node 依赖
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 系统文件
.DS_Store
Thumbs.db

# 编辑器
.vscode/
.idea/
*.swp
*.swo
